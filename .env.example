# ===== Supabase =====
# Project Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# 서버 전용 (절대 클라이언트에 노출 금지). RLS 우회가 필요한 배치/크론용
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===== 네이버 검색광고 API =====
# https://manage.searchad.naver.com > 도구 > API 사용 관리
NAVER_SEARCHAD_API_KEY=your-access-license
NAVER_SEARCHAD_SECRET_KEY=your-secret-key
NAVER_SEARCHAD_CUSTOMER_ID=your-customer-id

# ===== (선택) 네이버 데이터랩 - 키워드 트렌드 보조용 =====
NAVER_DATALAB_CLIENT_ID=
NAVER_DATALAB_CLIENT_SECRET=

# ===== 회원가입 제어 =====
# true로 설정하면 /signup에서 이메일/비밀번호 회원가입을 허용합니다.
# false 또는 미설정이면 회원가입 API가 403으로 닫힙니다.
SIGNUP_ENABLED=false
