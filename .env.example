# ===== Supabase =====
# Project Settings > API에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# 서버 전용입니다. 브라우저에 노출하면 안 됩니다.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===== 가입 신청 제어 =====
# false로 설정하면 /signup 신청 접수를 닫습니다. 미설정 또는 true면 신청을 받습니다.
SIGNUP_REQUESTS_ENABLED=true
# 선택: 쉼표로 구분한 관리자 이메일. Supabase app_metadata.role=admin도 관리자입니다.
ADMIN_EMAILS=

# ===== 네이버 검색광고 API =====
NAVER_SEARCHAD_API_KEY=your-access-license
NAVER_SEARCHAD_SECRET_KEY=your-secret-key
NAVER_SEARCHAD_CUSTOMER_ID=your-customer-id

# ===== 선택: 네이버 데이터랩 =====
NAVER_DATALAB_CLIENT_ID=
NAVER_DATALAB_CLIENT_SECRET=
